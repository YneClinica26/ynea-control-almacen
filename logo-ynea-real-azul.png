<!doctype html><html lang="es"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"><meta name="theme-color" content="#58C7E8"><title>YNEA Control de Almacén TEST v8.0.1</title><link rel="manifest" href="manifest.json"><link rel="apple-touch-icon" href="apple-touch-icon.png"><script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script><style>
:root{--blue:#58c7e8;--blue2:#0b8ed8;--dark:#123050;--muted:#6b7890;--line:#d8e8f4;--bg:#f7fbfe;--card:#fff;--danger:#e74c3c;--warn:#f5a623;--ok:#2eaa62}*{box-sizing:border-box}body{margin:0;font-family:Arial,Helvetica,sans-serif;background:var(--bg);color:var(--dark)}.app{display:grid;grid-template-columns:270px 1fr;min-height:100vh}.side{background:#fff;border-right:1px solid var(--line);padding:24px 16px;display:flex;flex-direction:column;gap:16px}.logo{width:190px;max-width:100%;margin:0 auto 10px;display:block}.subtitle{text-align:center;color:var(--blue2);font-weight:700;font-size:13px;margin-top:-10px}.nav{display:flex;flex-direction:column;gap:7px}.nav button,.cfg button,.quick button{border:1px solid transparent;background:transparent;padding:13px 14px;border-radius:12px;text-align:left;font-weight:700;color:var(--dark);cursor:pointer;font-size:15px}.nav button:hover,.nav button.active{background:#eaf7fd;color:var(--blue2);border-color:#c8edf9}.version{margin-top:auto;background:#eef8fd;border-radius:14px;padding:18px;text-align:center;color:var(--blue2);font-size:13px}.top{height:82px;background:#fff;border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;padding:0 28px}.badge{background:var(--blue2);color:white;padding:8px 14px;border-radius:8px;font-weight:700;margin-right:12px}.user{display:flex;align-items:center;gap:14px}.avatar{width:46px;height:46px;border-radius:50%;background:#dff4fc;display:grid;place-items:center;color:var(--blue2);font-size:23px}.logout,.mini{border:1px solid var(--line);background:#fff;color:var(--dark);border-radius:10px;padding:10px 12px;cursor:pointer;font-weight:700}.main{padding:24px 28px 70px}.title h1{margin:0 0 6px;font-size:28px}.title p{margin:0 0 20px;color:var(--muted)}.cards{display:grid;grid-template-columns:repeat(4,minmax(160px,1fr));gap:16px;margin-bottom:18px}.card,.panel{background:#fff;border:1px solid var(--line);border-radius:16px;padding:20px;box-shadow:0 6px 24px #0b8ed80a}.stat{display:flex;align-items:center;gap:18px}.ico{width:54px;height:54px;border-radius:50%;display:grid;place-items:center;background:#e3f5fc;color:var(--blue2);font-size:26px}.stat strong{font-size:30px}.stat span{display:block;color:var(--muted);margin-top:4px}.quick{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}.quick button{background:#f6fbfe;border:1px solid #cdebf7;display:flex;gap:14px;align-items:center}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:18px}.empty{text-align:center;color:var(--muted);padding:34px}.toolbar{display:flex;gap:10px;flex-wrap:wrap;margin:0 0 14px}.primary,.secondary,.dangerbtn{border:0;border-radius:10px;padding:11px 14px;font-weight:700;cursor:pointer}.primary{background:var(--blue2);color:#fff}.secondary{background:#eef8fd;color:var(--blue2);border:1px solid #cceefa}.dangerbtn{background:#fdebea;color:#b91c1c}.table{width:100%;border-collapse:collapse;background:#fff;border-radius:14px;overflow:hidden}.table th,.table td{padding:12px;border-bottom:1px solid var(--line);text-align:left}.table th{background:#eef8fd}.pill{display:inline-block;border-radius:999px;padding:5px 9px;font-size:12px;font-weight:700}.ok{background:#eaf8ef;color:var(--ok)}.warn{background:#fff4dc;color:#a66a00}.danger{background:#fdebea;color:var(--danger)}.cfg{display:grid;grid-template-columns:repeat(3,minmax(160px,1fr));gap:12px}.cfg button{background:#fff;border-color:var(--line);text-align:center}.modal{position:fixed;inset:0;background:#12305055;display:none;align-items:center;justify-content:center;padding:18px;z-index:50}.modal.open{display:flex}.box{background:#fff;border-radius:18px;max-width:760px;width:100%;max-height:92vh;overflow:auto;padding:22px;box-shadow:0 30px 80px #0003}.box header{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px}.x{border:0;background:#eef8fd;border-radius:9px;font-size:24px;width:40px;height:40px;cursor:pointer}.form{display:grid;grid-template-columns:1fr 1fr;gap:12px}.form label{display:flex;flex-direction:column;gap:6px;font-weight:700;font-size:13px}.form input,.form select,.form textarea{border:1px solid var(--line);border-radius:9px;padding:10px}.full{grid-column:1/-1}.bottom{display:none}.small{font-size:12px;color:var(--muted)}.list{display:grid;gap:10px}.item{border:1px solid var(--line);border-radius:12px;padding:12px;background:#fff;display:flex;justify-content:space-between;gap:12px;align-items:center}.item b{display:block}.item small{color:var(--muted)}.report-card{cursor:pointer}.report-card:hover{border-color:#9edff4;background:#f8fdff}.right{text-align:right}@media(max-width:850px){.app{display:block}.side{display:none}.top{height:auto;padding:12px 14px}.user .txt{display:none}.main{padding:16px 14px 86px}.cards,.quick,.grid2,.cfg{grid-template-columns:1fr}.form{grid-template-columns:1fr}.bottom{position:fixed;display:grid;grid-template-columns:repeat(5,1fr);bottom:0;left:0;right:0;background:#fff;border-top:1px solid var(--line);z-index:20}.bottom button{border:0;background:#fff;padding:10px 4px;color:var(--dark);font-weight:700}.bottom button.active{color:var(--blue2)}}

/* v7.8 ajuste móvil: evita pantalla desescalada y reorganiza la app */
html,body{width:100%;max-width:100%;overflow-x:hidden;-webkit-text-size-adjust:100%;}
img{max-width:100%;height:auto;}
.table{max-width:100%;}
@media(max-width:850px){
  body{font-size:15px;background:#f7fbfe;}
  .app{display:block;width:100%;max-width:100%;min-height:100vh;}
  section{width:100%;max-width:100%;}
  .top{position:sticky;top:0;z-index:15;width:100%;min-height:64px;padding:10px 12px;gap:8px;align-items:center;}
  .top>div:first-child{min-width:0;display:flex;flex-wrap:wrap;gap:6px;align-items:center;font-size:13px;}
  .badge{padding:6px 9px;margin-right:0;font-size:12px;}
  .user{gap:8px;flex-shrink:0;}
  .avatar{width:34px;height:34px;font-size:16px;}
  .logout{padding:8px 9px;font-size:12px;border-radius:9px;white-space:nowrap;}
  .main{width:100%;max-width:100%;padding:14px 10px 88px;overflow-x:hidden;}
  .title h1{font-size:22px;line-height:1.15;margin-bottom:6px;}
  .title p{font-size:14px;margin-bottom:14px;}
  .cards{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px;}
  .card,.panel{padding:13px;border-radius:14px;width:100%;max-width:100%;overflow:hidden;}
  .stat{gap:10px;}
  .ico{width:40px;height:40px;font-size:20px;flex:0 0 40px;}
  .stat strong{font-size:22px;}
  .stat span{font-size:12px;}
  .quick{grid-template-columns:1fr;gap:9px;}
  .quick button,.primary,.secondary,.dangerbtn,.mini{font-size:14px;padding:10px 11px;}
  .grid2,.cfg{grid-template-columns:1fr;gap:10px;}
  .toolbar{gap:8px;}
  .toolbar>*{max-width:100%;}
  .table{display:block;width:100%;overflow-x:auto;-webkit-overflow-scrolling:touch;white-space:nowrap;border-radius:12px;font-size:13px;}
  .table th,.table td{padding:9px 10px;}
  .item{align-items:flex-start;flex-direction:column;gap:8px;}
  .item .right{width:100%;text-align:left;display:flex;flex-wrap:wrap;gap:8px;}
  .modal{padding:8px;align-items:flex-start;overflow:auto;}
  .box{width:100%;max-width:100%;max-height:none;margin:8px 0 86px;padding:15px;border-radius:16px;}
  .box header h2{font-size:20px;margin:0;}
  .x{width:36px;height:36px;font-size:22px;}
  .form{grid-template-columns:1fr;gap:10px;}
  .form input,.form select,.form textarea{font-size:16px;min-height:42px;}
  .bottom{height:64px;grid-template-columns:repeat(5,1fr);padding-bottom:env(safe-area-inset-bottom);}
  .bottom button{font-size:11px;line-height:1.15;padding:8px 2px;}
}
@media(max-width:380px){.cards{grid-template-columns:1fr}.top{padding:8px}.main{padding-left:8px;padding-right:8px}.logout{font-size:11px;padding:7px}}


/* v7.9 — Línea visual unificada con Agenda YNEA y Control Horario */
:root{
  --blue:#58c7e8;
  --blue2:#23a9dc;
  --blue3:#dff5fc;
  --dark:#18324a;
  --muted:#6d7d8f;
  --line:#dcecf5;
  --bg:#f6fbfe;
  --card:#ffffff;
  --shadow:0 10px 30px rgba(24,50,74,.08);
}
body{font-family:Inter,Arial,Helvetica,sans-serif;background:linear-gradient(180deg,#f9fdff 0%,#eef9fd 100%);}
.app{grid-template-columns:258px 1fr;}
.side{padding:20px 14px;background:rgba(255,255,255,.96);box-shadow:8px 0 28px rgba(35,169,220,.05);}
.logo{width:176px;margin:0 auto 6px;}
.subtitle{font-size:12px;letter-spacing:.02em;color:var(--blue2);}
.nav{gap:6px;margin-top:4px;}
.nav button{height:44px;border-radius:13px;padding:10px 13px;font-size:14px;display:flex;align-items:center;gap:8px;}
.nav button:hover,.nav button.active{background:linear-gradient(90deg,#eaf8fd,#f7fcff);border-color:#bfeaf7;color:#168fc0;box-shadow:0 4px 14px rgba(35,169,220,.10);}
.version{border:1px solid #cfeef8;background:#f4fbfe;border-radius:16px;padding:14px;font-weight:700;}
.top{height:72px;padding:0 22px;background:rgba(255,255,255,.96);backdrop-filter:blur(8px);}
.badge{background:linear-gradient(135deg,var(--blue),var(--blue2));border-radius:999px;padding:7px 13px;box-shadow:0 6px 16px rgba(35,169,220,.18);}
.avatar{width:40px;height:40px;background:#e6f8fd;color:#1597c6;font-size:19px;}
.logout,.mini{border-radius:12px;background:#fff;border-color:#d5eaf4;}
.logout:hover,.mini:hover{background:#eff9fd;color:#168fc0;}
.main{padding:22px 24px 74px;}
.title h1{font-size:26px;font-weight:800;letter-spacing:-.02em;color:#17334c;}
.title p{font-size:14px;color:#748295;}
.cards{gap:14px;margin-bottom:16px;}
.card,.panel{border-radius:18px;border:1px solid var(--line);box-shadow:var(--shadow);background:rgba(255,255,255,.98);}
.card{padding:17px;}
.panel{padding:18px;}
.ico{width:48px;height:48px;background:linear-gradient(135deg,#e3f7fd,#f7fdff);color:#168fc0;box-shadow:inset 0 0 0 1px #cceff8;}
.stat strong{font-size:27px;line-height:1;}
.stat span{font-size:13px;}
.quick{gap:12px;}
.quick button{border-radius:14px;background:#fff;border-color:#d6edf7;box-shadow:0 7px 20px rgba(24,50,74,.05);min-height:48px;}
.quick button:hover{background:#eff9fd;border-color:#9be0f3;}
.primary,.secondary,.dangerbtn{border-radius:12px;min-height:42px;}
.primary{background:linear-gradient(135deg,var(--blue),var(--blue2));box-shadow:0 8px 18px rgba(35,169,220,.18);}
.secondary{background:#f2fbfe;border-color:#c7edf8;color:#168fc0;}
.table{border-radius:16px;box-shadow:0 7px 22px rgba(24,50,74,.04);}
.table th{background:#edf9fd;color:#24445c;font-size:13px;}
.table td{font-size:14px;}
.pill{border-radius:999px;padding:5px 10px;}
.cfg button{border-radius:16px;min-height:56px;background:#fff;box-shadow:0 7px 22px rgba(24,50,74,.04);}
.box{border-radius:22px;box-shadow:0 28px 80px rgba(24,50,74,.22);}
.form input,.form select,.form textarea{border-radius:12px;min-height:42px;background:#fbfdff;}
.form input:focus,.form select:focus,.form textarea:focus{outline:2px solid #bdebf7;border-color:#8adcf2;background:#fff;}
.bottom{box-shadow:0 -8px 28px rgba(24,50,74,.08);}

@media(max-width:850px){
  body{background:#f6fbfe;}
  .top{height:58px;min-height:58px;padding:8px 10px;border-bottom:1px solid #dcecf5;}
  .top>div:first-child{font-size:12px;gap:5px;}
  .badge{font-size:11px;padding:6px 9px;}
  .avatar{width:32px;height:32px;font-size:15px;}
  .logout{padding:7px 8px;font-size:11px;}
  .main{padding:12px 10px 82px;}
  .title h1{font-size:21px;margin-bottom:4px;}
  .title p{font-size:13px;margin-bottom:12px;}
  .cards{grid-template-columns:1fr 1fr;gap:9px;}
  .card,.panel{border-radius:16px;padding:12px;box-shadow:0 6px 18px rgba(24,50,74,.06);}
  .ico{width:38px;height:38px;font-size:18px;}
  .stat strong{font-size:21px;}
  .stat span{font-size:11.5px;}
  .quick button{min-height:46px;border-radius:14px;font-size:14px;}
  .table{font-size:12px;border-radius:14px;}
  .box{border-radius:18px;padding:14px;margin-top:6px;}
  .bottom{height:64px;background:#fff;border-top:1px solid #dcecf5;}
  .bottom button{font-size:10.5px;color:#4d5f72;}
  .bottom button.active{color:#168fc0;background:#f0fbfe;}
}

/* v8.0.1 SOLO UI: restauración logo + responsive móvil sin tocar lógica */
html{width:100%;min-width:0;-webkit-text-size-adjust:100%;text-size-adjust:100%;overflow-x:hidden;}
body{width:100%;min-width:0;overflow-x:hidden;}
.logoFallback{display:none;text-align:center;font-size:42px;line-height:1;font-weight:900;letter-spacing:.5px;color:#58c7e8;margin:4px auto 8px;}
.side .logo{display:block!important;object-fit:contain;height:auto;max-height:78px;}
.table{min-width:720px;}
.panel{min-width:0;}
.panel:has(.table){overflow-x:auto;-webkit-overflow-scrolling:touch;}
.item{min-width:0;}
@media(max-width:850px){
  body{position:relative;touch-action:manipulation;}
  .app{display:block;width:100%;min-width:0;}
  .top{position:sticky;top:0;z-index:15;min-height:58px;width:100%;padding:10px 12px;gap:8px;box-shadow:0 2px 12px #0b8ed80d;}
  .top>div:first-child{min-width:0;display:flex;align-items:center;gap:7px;overflow:hidden;}
  #dbState{font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:42vw;}
  .badge{padding:6px 9px;font-size:12px;margin-right:0;border-radius:9px;flex:0 0 auto;}
  .user{gap:7px;flex:0 0 auto;}
  .avatar{width:32px;height:32px;font-size:14px;}
  .logout{height:34px;padding:0 9px;font-size:11px;line-height:1;border-radius:10px;}
  .main{width:100%;max-width:100%;padding:14px 12px 84px;}
  .title h1{font-size:22px;line-height:1.15;margin-bottom:4px;}
  .title p{font-size:13px;margin-bottom:14px;}
  .cards{display:grid;grid-template-columns:1fr;gap:10px;margin-bottom:12px;}
  .card,.panel{border-radius:15px;padding:14px;box-shadow:0 4px 18px #0b8ed80a;}
  .stat{gap:12px;}
  .ico{width:42px;height:42px;font-size:20px;flex:0 0 auto;}
  .stat strong{font-size:24px;}
  .quick{display:grid;grid-template-columns:1fr;gap:10px;}
  .quick button,.nav button,.cfg button{min-height:44px;font-size:14px;padding:11px 12px;}
  .grid2,.cfg{display:grid;grid-template-columns:1fr;gap:12px;}
  .toolbar{gap:8px;overflow-x:auto;flex-wrap:nowrap;padding-bottom:2px;-webkit-overflow-scrolling:touch;}
  .toolbar button{white-space:nowrap;flex:0 0 auto;}
  .bottom{height:64px;grid-template-columns:repeat(5,1fr);padding-bottom:env(safe-area-inset-bottom);}
  .bottom button{font-size:11px;min-width:0;padding:7px 2px;}
  .modal{align-items:flex-end;padding:0;}
  .box{width:100%;max-width:100%;max-height:88vh;border-radius:18px 18px 0 0;padding:16px;overflow:auto;}
  .box header h2{font-size:19px;margin:0;}
  .form{grid-template-columns:1fr;gap:10px;}
  .form input,.form select,.form textarea{font-size:16px;min-height:42px;}
  .table{font-size:13px;min-width:680px;}
  .table th,.table td{padding:10px 8px;}
}
@media(max-width:390px){
  .main{padding-left:10px;padding-right:10px;}
  #dbState{max-width:36vw;}
  .title h1{font-size:20px;}
  .logout{font-size:10px;padding:0 7px;}
}

</style><!-- build: v8.0.1-solo-ui-logo-responsive -->
</head><body><div class="app"><aside class="side"><img src="logo-ynea-real-azul.png" class="logo" alt="YNEA" onerror="this.style.display='none';document.querySelector('.logoFallback').style.display='block'"> <div class="logoFallback">YNEA</div><div class="subtitle">CONTROL DE ALMACÉN</div><nav class="nav" id="nav"></nav><div class="version">Versión TEST v8.0.1<br>© 2026 YNEA</div></aside><section><header class="top"><div><span class="badge">TEST</span><span id="dbState">Pacientes: sin conectar</span></div><div class="user"><div class="avatar">●</div><div class="txt"><b id="userName">Administrador</b><br><small>Rol: Administrador</small></div><button class="logout" onclick="logout()">Cerrar sesión</button></div></header><main class="main" id="main"></main></section></div><nav class="bottom" id="bottom"></nav><div class="modal" id="modal"><div class="box"><header><h2 id="modalTitle">Formulario</h2><button class="x" onclick="closeModal()">×</button></header><div id="modalBody"></div></div></div><script>
const KEY='ynea_almacen_v773';
function loginHTML(){return `<div style="min-height:100vh;display:grid;place-items:center;background:#f7fbfe;font-family:Arial,Helvetica,sans-serif;color:#123050;padding:22px"><div style="width:100%;max-width:460px;background:white;border:1px solid #d8e8f4;border-radius:20px;padding:28px;box-shadow:0 22px 60px #0b8ed81a;text-align:center"><img src="logo-ynea-real-azul.png" alt="YNEA" style="width:210px;max-width:80%;margin-bottom:8px" onerror="this.outerHTML='<div style=&quot;font-size:42px;font-weight:900;color:#58c7e8;margin-bottom:8px&quot;>YNEA</div>'"><h1 style="margin:8px 0 4px;font-size:25px">Control de Almacén TEST</h1><p style="color:#6b7890;margin:0 0 12px">Introduce usuario y clave</p><input id="loginUser" placeholder="Nombre usuario" style="width:100%;box-sizing:border-box;margin:8px 0;padding:13px;border:1px solid #cfe7f1;border-radius:12px"><input id="loginPass" type="password" placeholder="Clave de acceso" style="width:100%;box-sizing:border-box;margin:8px 0 14px;padding:13px;border:1px solid #cfe7f1;border-radius:12px"><button onclick="login()" style="border:0;border-radius:12px;background:#0b8ed8;color:white;font-weight:700;padding:13px 20px;cursor:pointer;font-size:15px;width:100%">Entrar</button><p style="font-size:12px;color:#6b7890;margin-top:14px">Primer acceso: Admin / 1234</p><div id="loginMsg" style="color:#b42318;font-size:13px;margin-top:8px"></div></div></div>`}
function logout(){localStorage.setItem('ynea_almacen_session','0');localStorage.removeItem('ynea_almacen_current_user');document.body.innerHTML=loginHTML()}
function login(){const st=JSON.parse(localStorage.getItem(KEY)||JSON.stringify(defaultState));const u=(document.getElementById('loginUser')?.value||'').trim().toLowerCase();const p=(document.getElementById('loginPass')?.value||'').trim();const found=(st.usuarios||[]).find(x=>String(x[0]||'').toLowerCase()===u&&String(x[5]||'')===p&&String(x[4]||'Activo')==='Activo');if(!found){const m=document.getElementById('loginMsg');if(m)m.textContent='Usuario, clave o estado no válido';return}localStorage.setItem('ynea_almacen_session','1');localStorage.setItem('ynea_almacen_current_user',found[0]+' '+(found[1]||''));location.reload()}
const defaultState={categorias:['Medicación','Dispositivo médico','Fungibles','Instrumental','Material sanitario'],unidades:['Unidad','Caja','Blíster','Bolsa','Frasco','Kit'],productos:[['ALM-000001','DIU Mirena','Dispositivo médico','Unidad','5','Sí','Activo'],['ALM-000002','Guantes nitrilo','Fungibles','Caja','10','No','Activo'],['ALM-000003','Ácido hialurónico 1 ml','Medicación','Unidad','3','Sí','Activo']],lotes:[['DIU Mirena','MIR2601','31/12/2028','5','Activo'],['Guantes nitrilo','—','—','20','Activo'],['Ácido hialurónico 1 ml','AH2602','30/06/2027','2','Stock bajo']],proveedores:[['Proveedor ejemplo','B00000000','—','Activo']],usuarios:[['Admin','YNEA','','Administrador','Activo','1234']],entradas:[],salidas:[],pacientes:[],supabase:{tabla:'pacientes'},agendaUrl:'https://agenda-clinica-ynea.vercel.app'};let data=JSON.parse(localStorage.getItem(KEY)||JSON.stringify(defaultState));if(localStorage.getItem('ynea_almacen_session')!=='1'){document.body.innerHTML=loginHTML();throw new Error('Sesión cerrada')}if(document.getElementById('userName'))document.getElementById('userName').textContent=localStorage.getItem('ynea_almacen_current_user')||'Administrador';let current='Inicio';function save(){localStorage.setItem(KEY,JSON.stringify(data))}function esc(s){return String(s??'').replace(/[&<>"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m]))}const views=['Inicio','Stock','Entradas','Salidas','Inventario','Alertas','Productos','Proveedores','Informes','Configuración','Usuarios'];function renderNav(){document.getElementById('nav').innerHTML=views.map(v=>`<button class="${v==current?'active':''}" onclick="go('${v}')">${v}</button>`).join('');document.getElementById('bottom').innerHTML=['Inicio','Stock','Entradas','Salidas','Configuración'].map(v=>`<button class="${v==current?'active':''}" onclick="go('${v}')">${v}</button>`).join('');document.getElementById('dbState').textContent=data.pacientes.length?'Pacientes: '+data.pacientes.length:'Pacientes: sin conectar'}function go(v){current=v;renderNav();render()}function badge(x){x=esc(x);if(x==='Activo')return '<span class="pill ok">Activo</span>'; if(x==='Stock bajo')return '<span class="pill warn">Stock bajo</span>'; if(['Bloqueado','Caducado','Inactivo','Anulado'].includes(x))return '<span class="pill danger">'+x+'</span>'; return x}function table(head,rows,actions){return `<table class="table"><thead><tr>${head.map(h=>`<th>${h}</th>`).join('')}${actions?'<th>Acciones</th>':''}</tr></thead><tbody>${rows.map((r,i)=>`<tr>${r.map(c=>`<td>${badge(c)}</td>`).join('')}${actions?`<td>${actions(i)}</td>`:''}</tr>`).join('')}</tbody></table>`}
function todayISO(){return new Date().toISOString().slice(0,10)}
function parseDate(d){if(!d||d==='—')return null;const x=new Date(d.replace(/(\d{2})\/(\d{2})\/(\d{4})/,'$3-$2-$1'));return isNaN(x)?null:x}
function stockBajo(){return data.lotes.filter(l=>String(l[4]).toLowerCase().includes('stock bajo')||Number(l[3]||0)<=0||data.productos.some(p=>p[1]===l[0]&&Number(l[3]||0)<=Number(p[4]||0)))}
function caducados(){const now=new Date();now.setHours(0,0,0,0);return data.lotes.filter(l=>{const d=parseDate(l[2]);return d&&d<now})}
function caducidadesProximas(dias=90){const now=new Date();now.setHours(0,0,0,0);const lim=new Date(now);lim.setDate(lim.getDate()+dias);return data.lotes.filter(l=>{const d=parseDate(l[2]);return d&&d>=now&&d<=lim})}
function lotesBloqueados(){return data.lotes.filter(l=>String(l[4]).toLowerCase().includes('bloque'))}
function resumenList(rows,tipo){if(!rows.length)return '<div class="empty">Sin registros</div>';return '<div class="list">'+rows.map(r=>`<div class="item"><div><b>${esc(r[0])}</b><small>Lote: ${esc(r[1])} · Caducidad: ${esc(r[2])}</small></div><div class="right"><b>${esc(r[3])}</b><small>${esc(tipo||r[4])}</small></div></div>`).join('')+'</div>'}
function exportCSV(name,head,rows){const csv=[head,...rows].map(r=>r.map(v=>'"'+String(v??'').replace(/"/g,'""')+'"').join(';')).join('\n');const blob=new Blob([csv],{type:'text/csv;charset=utf-8'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=name+'.csv';a.click();URL.revokeObjectURL(a.href)}
function openReport(tipo){let head=[],rows=[],title='';
 if(tipo==='stock'){title='Informe stock actual';head=['Producto','Lote','Caducidad','Stock','Estado'];rows=data.lotes;}
 if(tipo==='entradas'){title='Informe entradas / compras';head=['Fecha','Proveedor','Factura'];rows=data.entradas;}
 if(tipo==='salidas'){title='Informe salidas / consumo';head=['Fecha','Paciente','Profesional','Producto','Cantidad'];rows=data.salidas;}
 if(tipo==='trazabilidad'){title='Informe trazabilidad clínica';head=['Fecha','Paciente','Profesional','Producto','Cantidad'];rows=data.salidas.filter(r=>data.productos.some(p=>p[1]===r[3]&&p[5]==='Sí'));}
 if(tipo==='caducidades'){title='Informe caducidades';head=['Producto','Lote','Caducidad','Stock','Estado'];rows=[...caducidadesProximas(90),...caducados()];}
 if(tipo==='precios'){title='Histórico de precios';head=['Producto','Proveedor','Fecha','Precio','Variación'];rows=[];}
 document.getElementById('modalTitle').textContent=title;
 document.getElementById('modalBody').innerHTML=`<div class="toolbar"><button class="primary" onclick='exportCSV(${JSON.stringify(title)},${JSON.stringify(head)},${JSON.stringify(rows)})'>Exportar Excel/CSV</button><button class="secondary" onclick="window.print()">Imprimir / PDF</button><button class="secondary" onclick="closeModal()">Cerrar</button></div>${rows.length?table(head,rows):'<div class="empty panel">Sin datos para este informe</div>'}`;
 document.getElementById('modal').classList.add('open')
}

function render(){let h='';if(current==='Inicio')h=`<div class="title"><h1>Inicio</h1><p>Resumen general del almacén con detalle de alertas.</p></div><div class="cards"><div class="card stat"><div class="ico">□</div><div><strong>${stockBajo().length}</strong><span>Stock bajo</span></div></div><div class="card stat"><div class="ico" style="background:#fff3dc;color:#d58500">▣</div><div><strong>${caducidadesProximas(90).length}</strong><span>Caducidades próximas</span></div></div><div class="card stat"><div class="ico" style="background:#fde7e7;color:#e74c3c">!</div><div><strong>${caducados().length}</strong><span>Caducados</span></div></div><div class="card stat"><div class="ico" style="background:#e8f8ee;color:#2eaa62">◉</div><div><strong>${data.pacientes.length}</strong><span>Pacientes cargados</span></div></div></div><div class="grid2"><div class="panel"><h2>Productos con stock bajo</h2>${resumenList(stockBajo(),'Stock bajo')}</div><div class="panel"><h2>Lotes próximos a caducar</h2>${resumenList(caducidadesProximas(90),'Próxima caducidad')}</div><div class="panel"><h2>Lotes caducados</h2>${resumenList(caducados(),'Caducado')}</div><div class="panel"><h2>Productos/lotes bloqueados</h2>${resumenList(lotesBloqueados(),'Bloqueado')}</div></div><div class="panel"><h2>Accesos rápidos</h2><div class="quick"><button onclick="openModal('entrada')"><span class="ico">+</span><span><b>Nueva entrada</b><br><small>Registrar entrada de productos</small></span></button><button onclick="openModal('salida')"><span class="ico">↪</span><span><b>Nueva salida</b><br><small>Registrar salida con paciente</small></span></button><button onclick="go('Informes')"><span class="ico">▤</span><span><b>Informes</b><br><small>Ver y exportar informes</small></span></button></div></div><div class="grid2"><div class="panel"><h2>Entradas recientes</h2>${data.entradas.length?table(['Fecha','Proveedor','Factura'],data.entradas.slice(-5)):('<div class="empty">No hay entradas registradas</div>')}</div><div class="panel"><h2>Salidas recientes</h2>${data.salidas.length?table(['Fecha','Paciente','Profesional','Producto','Cantidad'],data.salidas.slice(-5)):('<div class="empty">No hay salidas registradas</div>')}</div></div>`;else if(current==='Stock')h=`<div class="title"><h1>Stock</h1><p>Stock por producto, lote y caducidad.</p></div>${table(['Producto','Lote','Caducidad','Stock','Estado'],data.lotes)}`;else if(current==='Productos')h=`<div class="title"><h1>Productos</h1><p>Administrador puede crear categorías y productos.</p></div><div class="toolbar"><button class="primary" onclick="openModal('producto')">+ Producto</button><button class="secondary" onclick="openModal('categoria')">+ Categoría</button></div>${table(['Código','Producto','Categoría','Unidad','Stock mín.','Trazabilidad','Estado'],data.productos)}`;else if(current==='Proveedores')h=`<div class="title"><h1>Proveedores</h1><p>Varios proveedores por producto e histórico de precios.</p></div><button class="primary" onclick="openModal('proveedor')">+ Proveedor</button><br><br>${table(['Proveedor','CIF/NIF','Teléfono','Estado'],data.proveedores)}`;else if(current==='Entradas')h=`<div class="title"><h1>Entradas</h1><p>Factura de proveedor obligatoria.</p></div><button class="primary" onclick="openModal('entrada')">+ Nueva entrada</button><br><br>${data.entradas.length?table(['Fecha','Proveedor','Factura'],data.entradas):'<div class="empty panel">Sin entradas todavía</div>'}`;else if(current==='Salidas')h=`<div class="title"><h1>Salidas</h1><p>Una salida por paciente. Pacientes leídos desde Supabase si está configurado.</p></div><button class="primary" onclick="openModal('salida')">+ Nueva salida</button><br><br>${data.salidas.length?table(['Fecha','Paciente','Profesional','Producto','Cantidad'],data.salidas):'<div class="empty panel">Sin salidas todavía</div>'}`;else if(current==='Inventario')h=`<div class="title"><h1>Inventario</h1><p>Conteo móvil por producto + lote.</p></div><div class="toolbar"><button class="primary">+ Nuevo inventario</button><button class="secondary">Modo conteo móvil</button></div><div class="empty panel">Inventarios pendientes</div>`;else if(current==='Alertas')h=`<div class="title"><h1>Alertas</h1><p>Stock bajo, caducidades, bloqueos y diferencias.</p></div><div class="panel"><span class="pill warn">Stock bajo</span> Ácido hialurónico 1 ml está por debajo del stock mínimo.</div>`;else if(current==='Informes')h=`<div class="title"><h1>Informes</h1><p>Informes operativos con vista en pantalla y exportación Excel/CSV o PDF.</p></div><div class="cards"><div class="card report-card" onclick="openReport('stock')"><b>Stock actual</b><br><span class="small">Productos, lotes, caducidad y estado</span></div><div class="card report-card" onclick="openReport('entradas')"><b>Entradas / compras</b><br><span class="small">Proveedor, factura y fecha</span></div><div class="card report-card" onclick="openReport('salidas')"><b>Salidas / consumo</b><br><span class="small">Paciente, profesional y producto</span></div><div class="card report-card" onclick="openReport('trazabilidad')"><b>Trazabilidad clínica</b><br><span class="small">Solo productos con trazabilidad</span></div><div class="card report-card" onclick="openReport('caducidades')"><b>Caducidades</b><br><span class="small">Próximas y caducadas</span></div><div class="card report-card" onclick="openReport('precios')"><b>Histórico de precios</b><br><span class="small">Preparado para entradas con precio</span></div></div>`;else if(current==='Configuración')h=`<div class="title"><h1>Configuración</h1><p>Accesos de administrador.</p></div><div class="cfg"><button onclick="openModal('categoria')">Categorías</button><button onclick="openModal('unidad')">Unidades</button><button onclick="go('Usuarios')">Usuarios</button><button onclick="openModal('supabase')">Conectar con Agenda YNEA</button></div><br><div class="panel"><b>Estado pacientes:</b> ${data.pacientes.length} pacientes cargados.<br><span class="small">La app no modifica pacientes. Solo los lee para registrar salidas.</span></div>`;else if(current==='Usuarios')h=`<div class="title"><h1>Usuarios</h1><p>Gestión editable de usuarios.</p></div><button class="primary" onclick="openModal('usuario')">+ Usuario</button><br><br>${table(['Nombre','Apellidos','Teléfono','Rol','Estado'],data.usuarios.map(u=>u.slice(0,5)),i=>`<button class="mini" onclick="openModal('usuario',${i})">Editar</button>`)}`;document.getElementById('main').innerHTML=h}function closeModal(){document.getElementById('modal').classList.remove('open')}function openModal(type,idx){document.getElementById('modalTitle').textContent={producto:'Producto',categoria:'Categoría',unidad:'Unidad',proveedor:'Proveedor',entrada:'Nueva entrada',salida:'Nueva salida',usuario:idx>=0?'Editar usuario':'Nuevo usuario',supabase:'Conectar con Agenda YNEA'}[type]||'Formulario';let body='';if(type==='usuario'){let u=idx>=0?data.usuarios[idx]:['','','','Almacén / Recepción','Activo',''];body=`<div class="form"><label>Nombre<input id="uNom" value="${esc(u[0])}"></label><label>Apellidos<input id="uApe" value="${esc(u[1])}"></label><label>Teléfono<input id="uTel" value="${esc(u[2])}"></label><label>Rol<select id="uRol">${['Administrador','Almacén / Recepción','Profesional','Solo lectura'].map(r=>`<option ${u[3]===r?'selected':''}>${r}</option>`).join('')}</select></label><label>Estado<select id="uEst">${['Activo','Bloqueado','Inactivo'].map(r=>`<option ${u[4]===r?'selected':''}>${r}</option>`).join('')}</select></label><label class="full">Clave de acceso<input id="uClave" type="password" value="${esc(u[5]||'')}" placeholder="Clave obligatoria"></label><div class="full toolbar"><button class="primary" onclick="saveUsuario(${idx>=0?idx:-1})">Guardar usuario</button><button class="secondary" onclick="closeModal()">Cancelar</button></div></div>`}else if(type==='supabase'){body=`<div class="panel"><h3>Agenda Clínica YNEA</h3><p>Conecta con la base de pacientes de Agenda Clínica YNEA para buscar pacientes en las salidas.</p><p class="small">No modifica pacientes. Solo los consulta.</p><div class="toolbar"><button class="primary" onclick="loadPatients()">Activar conexión pacientes</button><button class="secondary" onclick="closeModal()">Cerrar</button></div><div id="sbMsg" class="small"></div></div>`}else if(type==='producto'){body=`<div class="form"><label>Nombre<input id="pNom"></label><label>Categoría<select id="pCat">${data.categorias.map(x=>`<option>${x}</option>`).join('')}</select></label><label>Unidad<select id="pUni">${data.unidades.map(x=>`<option>${x}</option>`).join('')}</select></label><label>Stock mínimo<input id="pMin" type="number" value="1"></label><label>Trazabilidad clínica<select id="pTra"><option>No</option><option>Sí</option></select></label><label>Estado<select id="pEst"><option>Activo</option><option>Bloqueado</option><option>Inactivo</option></select></label><button class="primary full" onclick="saveProducto()">Guardar producto</button></div>`}else if(type==='categoria'){body=`<div class="form"><label class="full">Nombre categoría<input id="catNom"></label><button class="primary full" onclick="let v=document.getElementById('catNom').value.trim();if(v){data.categorias.push(v);save();closeModal();render()}else alert('Indica categoría')">Guardar categoría</button></div>`}else if(type==='unidad'){body=`<div class="form"><label class="full">Nombre unidad<input id="uniNom" placeholder="Ej. Frasco 200 ml"></label><button class="primary full" onclick="let v=document.getElementById('uniNom').value.trim();if(v){data.unidades.push(v);save();closeModal();render()}else alert('Indica unidad')">Guardar unidad</button></div>`}else if(type==='proveedor'){body=`<div class="form"><label>Nombre<input id="prNom"></label><label>CIF/NIF<input id="prCif"></label><label>Teléfono<input id="prTel"></label><label>Estado<select id="prEst"><option>Activo</option><option>Bloqueado</option><option>Inactivo</option></select></label><button class="primary full" onclick="saveProveedor()">Guardar proveedor</button></div>`}else if(type==='entrada'){body=`<div class="form"><label>Fecha recepción<input id="eFecha" type="date"></label><label>Proveedor<input id="eProv"></label><label>Nº factura proveedor<input id="eFac"></label><label>Factura proveedor obligatoria<input type="file" accept=".pdf,.jpg,.jpeg,.png"></label><button class="primary full" onclick="saveEntrada()">Guardar entrada TEST</button></div>`}else if(type==='salida'){const pacientes=data.pacientes.map(p=>`<option value="${esc(p.id)}">${esc(p.nombreCompleto)}${p.telefono?' · '+esc(p.telefono):''}${p.email?' · '+esc(p.email):''}</option>`).join('');body=`<div class="form"><label class="full">Paciente ${data.pacientes.length?'<select id="sPac">'+pacientes+'</select>':'<input id="sPac" placeholder="Sin conexión: escribe paciente">'}</label>${data.pacientes.length?'<div class="full toolbar"><button class="secondary" type="button" onclick="openPacienteFicha()">Abrir ficha paciente</button><button class="secondary" type="button" onclick="openPacienteAgenda()">Abrir en Agenda YNEA</button></div>':''}<label>Profesional responsable<input id="sPro"></label><label>Producto<select id="sProd">${data.productos.map(p=>`<option>${esc(p[1])}</option>`).join('')}</select></label><label>Cantidad<input id="sCant" type="number" value="1"></label><button class="primary full" onclick="saveSalida()">Guardar salida</button></div>`}document.getElementById('modalBody').innerHTML=body;document.getElementById('modal').classList.add('open')}function saveUsuario(idx){let u=[uNom.value.trim(),uApe.value.trim(),uTel.value.trim(),uRol.value,uEst.value,uClave.value.trim()];if(!u[0]||!u[1])return alert('Nombre y apellidos son obligatorios');if(!u[5])return alert('La clave de acceso es obligatoria');if(idx>=0)data.usuarios[idx]=u;else data.usuarios.push(u);save();closeModal();render()}function saveProducto(){let n=pNom.value.trim();if(!n)return alert('Indica nombre');data.productos.push(['ALM-'+String(data.productos.length+1).padStart(6,'0'),n,pCat.value,pUni.value,pMin.value,pTra.value,pEst.value]);save();closeModal();render()}function saveProveedor(){if(!prNom.value.trim())return alert('Indica proveedor');data.proveedores.push([prNom.value.trim(),prCif.value.trim(),prTel.value.trim(),prEst.value]);save();closeModal();render()}function saveEntrada(){if(!eProv.value.trim()||!eFac.value.trim())return alert('Proveedor y Nº factura son obligatorios');data.entradas.push([eFecha.value||new Date().toISOString().slice(0,10),eProv.value.trim(),eFac.value.trim()]);save();closeModal();render()}function getPacienteSeleccionado(){if(!data.pacientes.length)return null;const val=document.getElementById('sPac')?.value;return data.pacientes.find(p=>String(p.id)===String(val))||data.pacientes.find(p=>p.nombreCompleto===val)||null}
function openPacienteFicha(){const p=getPacienteSeleccionado();if(!p)return alert('Selecciona un paciente');document.getElementById('modalTitle').textContent='Ficha paciente YNEA';document.getElementById('modalBody').innerHTML=`<div class="panel"><h3>${esc(p.nombreCompleto)}</h3><p><b>Teléfono:</b> ${esc(p.telefono||'—')}</p><p><b>Email:</b> ${esc(p.email||'—')}</p><p><b>ID YNEA:</b> ${esc(p.id||'—')}</p><p class="small">Ficha leída desde la tabla pacientes de Agenda YNEA. Desde Control de Almacén solo se consulta; no se modifica.</p></div><div class="toolbar"><button class="primary" onclick="openPacienteAgenda()">Abrir en Agenda YNEA</button><button class="secondary" onclick="closeModal()">Cerrar</button></div>`;document.getElementById('modal').classList.add('open')}
function openPacienteAgenda(){const p=getPacienteSeleccionado();if(!p)return alert('Selecciona un paciente');const base=(data.agendaUrl||'https://agenda-clinica-ynea.vercel.app').replace(/\/$/,'');const url=base+'/?paciente_id='+encodeURIComponent(p.id||'')+'&paciente='+encodeURIComponent(p.nombreCompleto||'');window.open(url,'_blank')}
function saveSalida(){if(!sPac.value||!sPro.value.trim())return alert('Paciente y profesional son obligatorios');let pac=sPac.value;if(data.pacientes.length){const p=getPacienteSeleccionado();pac=p?p.nombreCompleto:sPac.value}data.salidas.push([new Date().toISOString().slice(0,10),pac,sPro.value.trim(),sProd.value,sCant.value]);save();closeModal();render()}
function saveSupabase(){save()}
async function autoConnectPatients(){return loadPatients()}
async function loadPatients(){
  const msg=document.getElementById('sbMsg');
  const normalizar=(rows)=>rows.map(r=>({
    id:r.id||'',
    nombre:r.nombre||'',
    apellidos:'',
    telefono:r.telefono||'',
    email:r.email||'',
    observaciones:r.observaciones||'',
    nombreCompleto:(r.nombre||'Paciente sin nombre')
  })).sort((a,b)=>a.nombreCompleto.localeCompare(b.nombreCompleto));
  try{
    if(msg) msg.textContent='Conectando con pacientes YNEA...';
    let rows=[]; let detalle='';
    try{
      const res=await fetch('/api/pacientes?ts='+Date.now(),{cache:'no-store'});
      const txt=await res.text();
      let json={}; try{json=JSON.parse(txt)}catch(_){detalle=txt.slice(0,160)}
      if(res.ok && Array.isArray(json.pacientes)){ rows=json.pacientes; }
      else { detalle=json.error||detalle||('API interna HTTP '+res.status); }
    }catch(e){ detalle=e.message||'API interna no disponible'; }
    if(!rows.length){
      const url='https://vadohvwjoxghubceffpn.supabase.co';
      const key='sb_publishable_PM7HIrRvX8ShKW8yUFvh-w_ucW8ewwY';
      const endpoint=url+'/rest/v1/pacientes?select=id,nombre,telefono,email,observaciones&order=nombre.asc&limit=1000';
      const res2=await fetch(endpoint,{cache:'no-store',headers:{apikey:key,Authorization:'Bearer '+key,Accept:'application/json'}});
      const txt2=await res2.text();
      if(!res2.ok){ throw new Error('Supabase HTTP '+res2.status+': '+txt2.slice(0,220)); }
      rows=JSON.parse(txt2);
    }
    data.pacientes=normalizar(rows);
    save();
    if(msg) msg.textContent='Pacientes cargados correctamente: '+data.pacientes.length;
    renderNav();render();
  }catch(e){
    const texto=(e&&e.message)?e.message:'Error desconocido';
    if(msg) msg.textContent='No se pudo conectar con pacientes. Detalle: '+texto;
    else alert('No se pudo conectar: '+texto);
  }
}
renderNav();render();
</script></body></html>
